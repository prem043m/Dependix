{
  "name": "devsecops-assistant",
  "displayName": "DevSecOps Assistant",
  "description": "A structured sidebar for repository security scans and dependency checks.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devsecops.registerRepository",
        "title": "Register Repository",
        "icon": "$(repo-create)"
      },
      {
        "command": "devsecops.refreshPlatform",
        "title": "Refresh DevSecOps Data",
        "icon": "$(refresh)"
      },
      {
        "command": "devsecops.runSecurityScan",
        "title": "Run Security Scan",
        "icon": "$(shield)"
      },
      {
        "command": "devsecops.checkDependencies",
        "title": "Check Dependencies",
        "icon": "$(package)"
      },
      {
        "command": "devsecops.analyzeWorkflow",
        "title": "Analyze Workflow",
        "icon": "$(symbol-method)"
      },
      {
        "command": "devsecops.openRepository",
        "title": "Open GitHub Repository",
        "icon": "$(link-external)"
      },
      {
        "command": "devsecops.viewRepositoryDetails",
        "title": "View Repository Details",
        "icon": "$(preview)"
      },
      {
        "command": "devsecops.openRenovatePullRequest",
        "title": "Open Renovate Pull Request",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "devsecops.viewDependencyDetails",
        "title": "View Dependency Details",
        "icon": "$(preview)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devsecops",
          "title": "DevSecOps",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "devsecops": [
        {
          "id": "repositoriesView",
          "name": "Repositories"
        },
        {
          "id": "vulnerabilitiesView",
          "name": "Vulnerabilities"
        },
        {
          "id": "dependencyGovernanceView",
          "name": "Dependency Governance"
        },
        {
          "id": "securityScansView",
          "name": "Security Scans"
        },
        {
          "id": "scanHistoryView",
          "name": "Scan History"
        },
        {
          "id": "governanceAlertsView",
          "name": "Governance Alerts"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "repositoriesView",
        "contents": "Register repositories and inspect live governance data here.\n[Register repository](command:devsecops.registerRepository)"
      },
      {
        "view": "dependencyGovernanceView",
        "contents": "Live Renovate pull request intelligence will appear here.\n[Refresh platform data](command:devsecops.refreshPlatform)"
      }
    ],
    "configuration": {
      "title": "DevSecOps Assistant",
      "properties": {
        "devsecops.backendUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Base URL for the DevSecOps governance backend."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "devsecops.registerRepository",
          "when": "view == repositoriesView",
          "group": "navigation"
        },
        {
          "command": "devsecops.refreshPlatform",
          "when": "view == repositoriesView || view == vulnerabilitiesView || view == dependencyGovernanceView || view == securityScansView || view == scanHistoryView || view == governanceAlertsView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "devsecops.runSecurityScan",
          "when": "view == repositoriesView && viewItem == repository",
          "group": "inline"
        },
        {
          "command": "devsecops.checkDependencies",
          "when": "view == repositoriesView && viewItem == repository",
          "group": "inline"
        },
        {
          "command": "devsecops.analyzeWorkflow",
          "when": "view == repositoriesView && viewItem == repository",
          "group": "inline"
        },
        {
          "command": "devsecops.openRepository",
          "when": "view == repositoriesView && viewItem == repository",
          "group": "inline"
        },
        {
          "command": "devsecops.viewRepositoryDetails",
          "when": "view == repositoriesView && viewItem == repository",
          "group": "navigation"
        },
        {
          "command": "devsecops.viewRepositoryDetails",
          "when": "view == vulnerabilitiesView && viewItem == vulnerability",
          "group": "inline"
        },
        {
          "command": "devsecops.viewRepositoryDetails",
          "when": "view == securityScansView && viewItem == securityScan",
          "group": "inline"
        },
        {
          "command": "devsecops.viewRepositoryDetails",
          "when": "view == governanceAlertsView && viewItem == governanceAlert",
          "group": "inline"
        },
        {
          "command": "devsecops.openRenovatePullRequest",
          "when": "view == dependencyGovernanceView && viewItem == dependency",
          "group": "inline"
        },
        {
          "command": "devsecops.viewDependencyDetails",
          "when": "view == dependencyGovernanceView && viewItem == dependency",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "axios": "^1.16.1",
    "socket.io-client": "^4.8.3"
  }
}
